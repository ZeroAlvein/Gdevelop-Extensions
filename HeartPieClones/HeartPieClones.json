                        "value": "Create"
                      },
                      "parameters": [
                        "",
                        "Object",
                        "Z[ID][\"StartX\"] + (Z[ID][\"DistanceX\"] * (Z[ID][\"AdvX\"] * abs(Z[ID][\"Switch\"] - 1) + (Z[ID][\"AdvY\"] * Z[ID][\"Switch\"])))",
                        "Z[ID][\"StartY\"] + (Z[ID][\"DistanceY\"] * (Z[ID][\"AdvY\"] * abs(Z[ID][\"Switch\"] - 1) + (Z[ID][\"AdvX\"] * Z[ID][\"Switch\"])))",
                        "Layer"
                      ]
                    },
                    {
                      "type": {
                        "value": "ScalableCapability::ScalableBehavior::SetValue"
                      },
                      "parameters": [
                        "Object",
                        "Scale",
                        "=",
                        "Z[ID][\"Scale\"]"
                      ]
                    },
                    {
                      "type": {
                        "value": "ModVarObjetTxt"
                      },
                      "parameters": [
                        "Object",
                        "Z[ID][\"Profile\"]",
                        "=",
                        "ID"
                      ]
                    },
                    {
                      "type": {
                        "value": "ModVarObjet"
                      },
                      "parameters": [
                        "Object",
                        "Z[ID][\"X\"]",
                        "=",
                        "((Z[ID][\"DistanceX\"] * (1 - (2 * Z[ID][\"LR\"]))) * (Z[ID][\"AdvX\"] * abs(Z[ID][\"Switch\"] - 1) + (Z[ID][\"AdvY\"] * Z[ID][\"Switch\"])))"
                      ]
                    },
                    {
                      "type": {
                        "value": "ModVarObjet"
                      },
                      "parameters": [
                        "Object",
                        "Z[ID][\"Y\"]",
                        "=",
                        "((Z[ID][\"DistanceY\"] * (1 - (2 * Z[ID][\"UD\"]))) * (Z[ID][\"AdvY\"] * abs(Z[ID][\"Switch\"] - 1) + (Z[ID][\"AdvX\"] * Z[ID][\"Switch\"])))"
                      ]
                    },
                    {
                      "type": {
                        "value": "AnimatableCapability::AnimatableBehavior::SetIndex"
                      },
                      "parameters": [
                        "Object",
                        "Animation",
                        "=",
                        "Z[ID][\"Animation\"]"
                      ]
                    },
                    {
                      "type": {
                        "value": "AnimatableCapability::AnimatableBehavior::PauseAnimation"
                      },
                      "parameters": [
                        "Object",
                        "Animation"
                      ]
                    },
                    {
                      "type": {
                        "value": "ChangeSprite"
                      },
                      "parameters": [
                        "Object",
                        "=",
                        "abs(((Z[ID][\"Frames\"] -1) * ToNumber(Z[ID][\"Order\"])) - (clamp(clamp(trunc(Z[ID][\"HP\"]), 0, Z[ID][\"Clones\"] * (Z[ID][\"Frames\"] - 1)) - Z[ID][\"Multi\"] * (Z[ID][\"Frames\"] - 1), 0, Z[ID][\"Frames\"] - 1)))"
                      ]
                    },
                    {
                      "type": {
                        "value": "SetNumberVariable"
                      },
                      "parameters": [
                        "Z[ID][\"AdvX\"]",
                        "+",
                        "1"
                      ]
                    },
                    {
                      "type": {
                        "value": "SetNumberVariable"
                      },
                      "parameters": [
                        "Z[ID][\"Multi\"]",
                        "+",
                        "1"
                      ]
